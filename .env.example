# ================================================================
#  Sing-Box Plus — Docker Container Configuration
#  For Back4App Containers deployment
#  Inspired by: https://github.com/Alvin9999-newpac/Sing-Box-Plus
# ================================================================

# ---- Proxy Port (non-standard, 10000-65535 range) ----
# Mirrors Sing-Box-Plus gen_port() pattern: random port in 10000-65535
# Change this to any unused port, or generate randomly on each deploy
SING_BOX_PORT=31080

# ---- UUID (VLESS user identifier) ----
# Mirrors Sing-Box-Plus gen_uuid() pattern
# Your generated UUID — do not change after clients are configured
SING_BOX_UUID=524bd2ea-9579-4b31-b4ed-480ab6068578

# ---- Protocol Type ----
# Supported: vless (default), trojan, hysteria2, vmess
# Mirrors Sing-Box-Plus ENABLE_* flags
SING_BOX_PROTOCOL=vless

# ---- WebSocket Path ----
# Mirrors Sing-Box-Plus VMESS_WS_PATH constant
SING_BOX_WS_PATH=/chat

# ---- Reality Server (SNI domain for TLS handshake) ----
# Mirrors Sing-Box-Plus REALITY_SERVER constant
# Must be a domain that supports TLS 1.3 + HTTP/2, not blocked
SING_BOX_REALITY_SERVER=www.microsoft.com

# ---- Log Level ----
# Options: debug, info, warn, error
# Mirrors Sing-Box-Plus log level: "info"
SING_BOX_LOG_LEVEL=info

# ---- Health Check Port ----
# Separate port for Back4App health monitoring
# Mirrors Sing-Box-Plus ensure_deps() philosophy: keep services lightweight
SING_BOX_HEALTH_PORT=31081
